{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "approval-request-withdrawn-v1",
  "title": "APPROVAL_REQUEST_WITHDRAWN",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "eventType",
    "schemaVersion",
    "occurredAt",
    "correlationId",
    "actor",
    "entity",
    "action",
    "outcome",
    "attributes"
  ],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "const": "APPROVAL_REQUEST_WITHDRAWN" },
    "schemaVersion": { "const": 1 },
    "occurredAt": { "type": "string", "format": "date-time" },
    "correlationId": { "type": "string", "format": "uuid" },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": { "const": "user" },
        "id": { "type": "string", "format": "uuid" }
      }
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": { "const": "approval-request" },
        "id": { "type": "string", "format": "uuid" }
      }
    },
    "action": { "const": "withdraw" },
    "outcome": { "const": "success" },
    "attributes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["previousStatus", "newStatus", "requestVersion"],
      "properties": {
        "previousStatus": { "const": "Submitted" },
        "newStatus": { "const": "Withdrawn" },
        "requestVersion": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
